{
  "name": "@tukuyomil032/bricklayer",
  "private": false,
  "version": "1.0.44",
  "description": "Interactive TypeScript CLI project scaffolder",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "bin": {
    "brick": "./dist/index.js"
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "postbuild": "node -e \"require('fs').chmodSync('dist/index.js', 0o755)\"",
    "prepare": "husky",
    "prepublishOnly": "pnpm run build",
    "dev": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "format": "biome format --write",
    "lint": "biome lint --write",
    "biome:check": "biome check",
    "lint-staged": "lint-staged"
  },
  "keywords": ["cli", "scaffold", "typescript", "generator"],
  "author": "tukuyomil032",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tukuyomil032/bricklayer.git"
  },
  "bugs": {
    "url": "https://github.com/tukuyomil032/bricklayer/issues"
  },
  "homepage": "https://github.com/tukuyomil032/bricklayer#readme",
  "dependencies": {
    "chalk": "^5.3.0",
    "cli-progress": "^3.12.0",
    "commander": "^11.1.0",
    "enquirer": "^2.4.1",
    "inquirer": "^9.2.11",
    "ora": "^8.1.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.9",
    "@types/cli-progress": "^3.11.6",
    "@types/inquirer": "^9.0.9",
    "@types/node": "^22.10.5",
    "globals": "^17.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "ts-node": "^10.9.1",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.53.1"
  },
  "lint-staged": {
    "*.ts": ["biome format --write", "biome lint --write"]
  },
  "packageManager": "pnpm@10.27.0"
}
